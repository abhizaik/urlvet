# Cache/Valkey Configuration
CACHE_ADDR=safesurf-valkey-dev:6379 # safesurf-valkey:6379
CACHE_PASSWORD=
CACHE_DB=0
CACHE_POOL_SIZE=50
CACHE_MIN_IDLE_CONNS=10

# Server Configuration
ENV=DEV
PORT=8080
LOG_TIMEZONE=UTC          # e.g. Asia/Kolkata, America/New_York, Europe/London
LOG_DIR=logs              # directory for rotating daily log files; leave empty to disable
CORS_ALLOWED_ORIGINS=https://safesurf.xorwave.com,https://url.vet
ADMIN_PASSWORD_HASH=''                   # use single quotes — see docs/security.md for how to generate
ADMIN_JWT_SECRET=                        # generate: openssl rand -hex 32
